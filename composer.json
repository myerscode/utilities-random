{
  "name": "myerscode/utilities-random",
  "description": "A PHP utility class that creates a fluent random value generator",
  "keywords": [
    "random",
    "text",
    "number",
    "utility",
    "library",
    "chaining",
    "fluent"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "myerscode",
      "email": "team@myerscode.com",
      "homepage": "https://myerscode.com"
    },
    {
      "name": "Fred Myerscough",
      "email": "fred@myerscough.co.uk",
      "homepage": "https://fredmyerscough.co.uk"
    }
  ],
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "phpunit/phpunit": "^13.0",
    "rector/rector": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "Myerscode\\Utilities\\Random\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "vendor/bin/pint --test",
    "lint-fix": "vendor/bin/pint",
    "tests": "vendor/bin/phpunit --testdox --no-coverage --colors=always",
    "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --testdox --colors=always"
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  }
}
